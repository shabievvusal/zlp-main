# ─── Зависимости ───────────────────────────────────────────────
node_modules/
frontend/app/node_modules/

# ─── Сборка ────────────────────────────────────────────────────
frontend/app/dist/
tools/*/bin/
tools/*/obj/

# ─── Данные (генерируются в рантайме) ──────────────────────────
backend/data/
backend/uploads/

# ─── Секреты и конфиги с токенами ──────────────────────────────
.env
backend/config.json

# ─── Пользователи (настраиваются при деплое) ───────────────────
backend/vs-users.json

# ─── Рабочие данные (не код) ───────────────────────────────────
backend/data.xlsx
backend/*.xlsx
backend/*.json.default

# ─── Загруженные файлы с данными в корне проекта ───────────────
/*.json
/*.xlsx

# ─── Логи и временные файлы ────────────────────────────────────
*.log
owms.log
*.zip
*.7z

# ─── IDE ───────────────────────────────────────────────────────
.claude/
.idea/
.vscode/

# ─── Панель управления — отдельный репозиторий ─────────────────
panel/
