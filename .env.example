# Порт приложения (по умолчанию 3001 — чтобы не конфликтовать с другим проектом на 3000)
PORT=3007

# Агент ноды — для связи с панелью управления
# Сгенерировать: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NODE_TOKEN=your_random_secret_here
NODE_NAME=Нода

# S3-совместимое хранилище (RustFS / MinIO)
S3_ENDPOINT=http://YOUR_MEDIA_SERVER_IP:9000
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=zlp-media
S3_PUBLIC_URL=http://YOUR_MEDIA_SERVER_IP:9000
